create table public.empresa (
  id_empresa bigint generated by default as identity not null,
  id_pais text not null,
  empresa text not null,
  constraint empresa_pkey primary key (id_empresa),
  constraint empresa_empresa_key unique (empresa),
  constraint empresa_id_pais_key unique (id_pais),
  constraint empresa_empresa_fkey foreign KEY (empresa) references ia (ia),
  constraint empresa_empresa_fkey3 foreign KEY (empresa) references ia (usuarios),
  constraint empresa_empresa_fkey1 foreign KEY (empresa) references ia ("gasto anual"),
  constraint empresa_empresa_fkey2 foreign KEY (empresa) references ia ("crecimento anual")
) TABLESPACE pg_default;
