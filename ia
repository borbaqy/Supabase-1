create table public.ia (
  id_ia bigint generated by default as identity not null,
  ia text not null,
  consumo de agua text not null,
  gasto anual text not null,
  crecimento anual text not null,
  usuarios text not null,
  constraint ia_pkey primary key (id_ia),
  constraint ia_consumo de agua_key unique ("consumo de agua"),
  constraint ia_crecimento anual_key unique ("crecimento anual"),
  constraint ia_gasto anual_key unique ("gasto anual"),
  constraint ia_ia_key unique (ia),
  constraint ia_usuarios_key unique (usuarios)
) TABLESPACE pg_default;
